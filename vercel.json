{
  "version": 2,
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "builds": [
    {
      "src": "dist/e-commerce-rose/server/entry.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/e-commerce-rose/browser/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/.*", "dest": "api/index.mjs" }
  ]
}
